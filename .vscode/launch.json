{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask App (Docker)",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "app.py",
                "FLASK_ENV": "development"
            },
            "args": ["run", "--host=0.0.0.0"],
            "dockerOptions": {
                "containerName": "flask-webapp",
                "image": "flask-webapp"
            }
        }
    ]
}
